@startuml
' Architecture multi-agents + skills du projet histoire_suisse
left to right direction
skinparam shadowing false
skinparam packageStyle rectangle
skinparam defaultFontName Arial
skinparam ArrowColor #4C566A
skinparam packageBorderColor #5E81AC
skinparam packageBackgroundColor #ECEFF4
skinparam rectangleBorderColor #5E81AC
skinparam rectangleBackgroundColor #FFFFFF
skinparam noteBackgroundColor #FFF8DC
skinparam noteBorderColor #D08770

title Architecture du projet histoire_suisse\nAgents, skills, corpus et livrables

package "Sources externes" as EXT {
  rectangle "Swissvotes" as SW
  rectangle "DHS" as DHS
  rectangle "e-newspaperarchives" as ENP
  rectangle "Dodis" as DODIS
  rectangle "Wikipedia" as WIKI
  rectangle "EliteSuisses CSV" as ELITE
}

package "Skills - collecte" as SK_COLLECT {
  rectangle "fetch-swissvote-votation-sources" as S_SW
  rectangle "fetch-dhs-article" as S_DHS
  rectangle "fetch-enewspaper-article-list" as S_ENP_LIST
  rectangle "fetch-enewspaper-article-content" as S_ENP_CONTENT
  rectangle "fetch-dodis-results" as S_DODIS_RES
  rectangle "fetch-dodis-person-details" as S_DODIS_PERSON
  rectangle "fetch-wikipedia-article" as S_WIKI
  rectangle "fetch-elitesuisse-person-details" as S_ELITE
}

package "Skills - transformation" as SK_TRANSFORM {
  rectangle "extract-pdf-to-md" as S_PDF
  rectangle "extract-pdf-to-md-all-sources" as S_PDF_ALL
  rectangle "translate-markdown" as S_TRANSLATE
}

package "Corpus local" as CORPUS {
  collections "sources/" as SRC
  rectangle "table source\ndans named_entities.sqlite" as IDX
  rectangle "sources/named_entities.sqlite" as NEDB
}

package "Skills - indexation et données" as SK_DATA {
  rectangle "indexer-sources" as S_INDEX
  rectangle "manage-named-entities-db" as S_NE
  rectangle "startup-research" as S_START
}

package "Skills - analyses thématiques" as SK_ANALYSIS {
  rectangle "analyse-swissvotes-votations" as A_SW
  rectangle "analyse-resultats-votation" as A_RES
  rectangle "analyse-population-suisse" as A_POP
  rectangle "analyse-dynamique-historique" as A_DYN
  rectangle "analyse-champ-lexical" as A_LEX
}

SK_TRANSFORM -[hidden]down-> CORPUS

package "Agents d'orchestration (.agents/agent_*.md)" as AGENTS {
  rectangle "agent_categorisation_de_source" as AG_CAT
  rectangle "agent_contexte_historique" as AG_CTX
  rectangle "agent_analyse_campagne" as AG_CAM
  rectangle "agent_analyse_politique_suisse" as AG_POL
  rectangle "agent_validation_chronologique" as AG_VAL
  rectangle "agent_evaluation_critique" as AG_EVAL
}

rectangle "sortie/*.md\nsortie/*.json" as OUT

SW --> S_SW
DHS --> S_DHS
ENP --> S_ENP_LIST
ENP --> S_ENP_CONTENT
DODIS --> S_DODIS_RES
DODIS --> S_DODIS_PERSON
WIKI --> S_WIKI
ELITE --> S_ELITE

S_SW --> SRC
S_DHS --> SRC
S_ENP_CONTENT --> SRC
S_DODIS_RES --> SRC
S_DODIS_PERSON --> SRC
S_WIKI --> SRC
S_ELITE --> SRC

SRC --> S_PDF
SRC --> S_PDF_ALL
SRC --> S_TRANSLATE
S_PDF --> SRC
S_PDF_ALL --> SRC
S_TRANSLATE --> SRC

SRC --> S_INDEX
S_INDEX --> IDX
SRC --> S_NE
S_NE --> NEDB
S_START --> OUT

IDX --> AG_CAT
SRC --> AG_CAT
AG_CAT --> AG_CTX
AG_CTX --> AG_CAM
AG_CAM --> AG_POL
AG_POL --> AG_VAL
AG_VAL --> AG_EVAL
AG_EVAL --> OUT

IDX --> A_SW
IDX --> A_RES
IDX --> A_POP
SRC --> A_DYN
SRC --> A_LEX

A_SW --> OUT
A_RES --> OUT
A_POP --> OUT
A_DYN --> OUT
A_LEX --> OUT

note bottom of AG_VAL
Vérifie la cohérence chronologique
et l'appui explicite sur les sources.
end note





@enduml
